// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())

  // Relations
  memberships        CourseMembership[]
  queueEntries       QueueEntry[]
  officeHourSessions OfficeHourSession[]

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Course {
  id        String   @id @default(cuid())
  code      String
  name      String
  semester  String
  createdAt DateTime @default(now())

  // Relations
  memberships        CourseMembership[]
  officeHourSessions OfficeHourSession[]

  @@unique([code, semester]) // Can't have duplicate CSC110 in Winter 2025
  @@map("courses")
}

enum CourseRole {
  STUDENT
  TA
  INSTRUCTOR
}

model CourseMembership {
  id       String     @id @default(cuid())
  userId   String
  courseId String
  role     CourseRole

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, courseId]) // A user can only have one role per course
  @@map("course_memberships")
}

model OfficeHourSession {
  id           String @id @default(cuid())
  courseId     String
  instructorId String // TA or instructor running this session

  title     String?
  startTime DateTime
  endTime   DateTime
  location  String?
  isActive  Boolean  @default(false)

  createdAt DateTime @default(now())

  // Relations
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor   User         @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  queueEntries QueueEntry[]

  @@map("office_hour_sessions")
}

enum QueueStatus {
  WAITING
  IN_PROGRESS
  RESOLVED
  SKIPPED
  NO_SHOW
}

model QueueEntry {
  id        String      @id @default(cuid())
  sessionId String
  studentId String
  question  String?
  status    QueueStatus @default(WAITING)
  position  Int? // For ordering the queue

  // Timestamps for analytics
  createdAt  DateTime  @default(now())
  startedAt  DateTime?
  resolvedAt DateTime?

  // Relations
  session OfficeHourSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User              @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("queue_entries")
}

// ============================================
// NEXTAUTH MODELS
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
